# ------------------------------------------------------------------
# Agrofix configuration. Copy to `.env` and fill in.
# The app runs WITHOUT any of these — it falls back to sample data and
# clearly labels itself as "sample". Add keys to go live, one feed at a time.
# ------------------------------------------------------------------

PORT=3000

# --- Commodity prices (the only feed you pay for) ---------------------------
# Provider: "commodities-api" | "twelvedata" | "none"
# "none" (default) = use curated benchmark prices, labelled sample.
COMMODITY_PROVIDER=none
COMMODITY_API_KEY=
# How often to refresh commodity prices. Soft commodities move slowly;
# 4x/day is plenty and keeps you inside cheap tiers. Value in minutes.
COMMODITY_TTL_MINUTES=360

# --- FX rates (free, no key needed) -----------------------------------------
# Uses open.er-api.com by default. Leave as-is.
FX_TTL_MINUTES=720

# --- Weather (free, no key needed) ------------------------------------------
# Uses Open-Meteo by default. Leave as-is.
WEATHER_TTL_MINUTES=180
# Set to "false" to skip live weather and use curated weather only.
WEATHER_LIVE=true

# --- Payments (optional — only if you gate the terminal) --------------------
# Leave PAYSTACK_SECRET blank to keep the app fully free/open.
# Use Paystack or Flutterwave in Nigeria (Stripe does not pay out to NG).
PAYSTACK_SECRET=
PAYSTACK_PUBLIC=
# Price of a Pro subscription, in kobo (₦1 = 100 kobo). e.g. 500000 = ₦5,000
PAYSTACK_PLAN_AMOUNT=500000
